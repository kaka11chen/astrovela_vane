#==============================================================================#
# General
#==============================================================================#
# Temp files created by most text editors.
*~
# Merge files created by git.
*.orig
# vim swap files
.*.sw?
.sw?
#OS X specific files.
.DS_store
#VSCode specifics
.vscode/
.cache/

